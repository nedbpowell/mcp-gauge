{
  "name": "mcp-gauge",
  "version": "0.1.0",
  "type": "module",
  "description": "See exactly which MCP tools are eating your context window. Disable the deadweight.",
  "author": "Ned Powell <nedbaynepowell@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/nedbpowell/mcp-gauge"
  },
  "main": "dist/index.js",
  "bin": {
    "mcp-gauge": "./bin/mcp-gauge.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm --test \"test/**/*.test.ts\""
  },
  "keywords": [
    "mcp",
    "claude",
    "context",
    "tokens",
    "tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "express": "^4.18.0",
    "smol-toml": "^1.7.0",
    "tiktoken": "^1.0.15",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
